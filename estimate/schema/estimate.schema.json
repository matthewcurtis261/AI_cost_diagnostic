{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/diagnostic-agent/estimate.schema.json",
  "title": "AI Spend Estimate",
  "description": "Cost estimate from findings and/or telemetry events",
  "type": "object",
  "required": ["estimate_metadata", "line_items", "totals", "savings_opportunities", "coverage_notes"],
  "additionalProperties": false,
  "properties": {
    "estimate_metadata": {
      "type": "object",
      "required": [
        "generated_at",
        "schema_version",
        "mode",
        "findings_source",
        "pricing_as_of",
        "currency",
        "period"
      ],
      "additionalProperties": false,
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "schema_version": { "type": "string", "const": "0.1.0" },
        "mode": { "type": "string", "enum": ["code_only", "telemetry"] },
        "findings_source": { "type": "string", "minLength": 1 },
        "events_source": { "type": "string" },
        "pricing_as_of": { "type": "string" },
        "currency": { "type": "string", "minLength": 1 },
        "period": { "type": "string", "enum": ["month", "day", "event_window"] },
        "pricing_sources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "line_items": {
      "type": "array",
      "items": { "$ref": "#/definitions/line_item" }
    },
    "totals": {
      "type": "object",
      "required": ["calls", "input_tokens", "output_tokens", "source", "total_usd"],
      "additionalProperties": false,
      "properties": {
        "calls": { "type": "integer", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "source": { "type": "string", "enum": ["telemetry", "assumed", "mixed"] },
        "total_usd": { "type": "number", "minimum": 0 }
      }
    },
    "savings_opportunities": {
      "type": "array",
      "items": { "$ref": "#/definitions/savings_opportunity" }
    },
    "coverage_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "line_item": {
      "type": "object",
      "required": [
        "finding_id",
        "provider",
        "model",
        "call_type",
        "location",
        "usage",
        "cost",
        "pricing_model_resolved"
      ],
      "additionalProperties": false,
      "properties": {
        "finding_id": { "type": "string", "pattern": "^f[0-9]{3,}$" },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "call_type": { "type": "string" },
        "location": {
          "type": "object",
          "required": ["file", "lines"],
          "properties": {
            "file": { "type": "string" },
            "lines": { "type": "array", "items": { "type": "integer", "minimum": 1 } }
          }
        },
        "usage": {
          "type": "object",
          "required": ["calls", "input_tokens", "output_tokens", "source"],
          "properties": {
            "calls": { "type": "integer", "minimum": 0 },
            "input_tokens": { "type": "integer", "minimum": 0 },
            "output_tokens": { "type": "integer", "minimum": 0 },
            "source": { "type": "string", "enum": ["telemetry", "assumed", "mixed"] }
          }
        },
        "cost": {
          "type": "object",
          "required": ["input_usd", "output_usd", "total_usd"],
          "properties": {
            "input_usd": { "type": "number", "minimum": 0 },
            "output_usd": { "type": "number", "minimum": 0 },
            "total_usd": { "type": "number", "minimum": 0 }
          }
        },
        "pricing_model_resolved": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "savings_opportunity": {
      "type": "object",
      "required": [
        "finding_id",
        "current_model",
        "alternative_model",
        "current_total_usd",
        "alternative_total_usd",
        "savings_usd",
        "savings_percent",
        "compatible"
      ],
      "additionalProperties": false,
      "properties": {
        "finding_id": { "type": "string" },
        "current_model": { "type": "string" },
        "alternative_model": { "type": "string" },
        "current_total_usd": { "type": "number" },
        "alternative_total_usd": { "type": "number" },
        "savings_usd": { "type": "number" },
        "savings_percent": { "type": "number" },
        "compatible": { "type": "boolean" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
