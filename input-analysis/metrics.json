{
  "schema_version": "0.1.0",
  "description": "Granular quality metric families for input-aware diagnostic routing. Scores are normalized 0-1.",
  "metrics": [
    {
      "id": "mcq_knowledge",
      "label": "General knowledge (MCQ)",
      "benchmarks": ["MMLU", "MMLU-Pro"],
      "oll_columns": ["MMLU-PRO Raw", "MMLU-PRO"],
      "score_kind": "accuracy"
    },
    {
      "id": "expert_science",
      "label": "Expert science reasoning",
      "benchmarks": ["GPQA Diamond", "HLE"],
      "oll_columns": ["GPQA Raw", "GPQA"],
      "score_kind": "accuracy"
    },
    {
      "id": "math",
      "label": "Mathematical reasoning",
