      "score_kind": "accuracy"
    },
    {
      "id": "multi_step_reasoning",
      "label": "Multi-step reasoning",
      "benchmarks": ["BBH", "MuSR"],
      "oll_columns": ["BBH Raw", "BBH", "MUSR Raw", "MUSR"],
      "score_kind": "accuracy",
