{
  "name": "diagnostic-agent",
  "version": "0.1.0",
  "description": "Discover AI/LLM API usage in codebases via Nanoclaw",
  "type": "module",
  "bin": {
    "diagnostic-agent": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx cli/index.ts",
    "setup": "tsx cli/index.ts setup",
    "scan": "tsx cli/index.ts scan",
    "discover": "tsx cli/index.ts discover",
    "check": "tsx cli/index.ts check",
    "estimate": "tsx cli/index.ts estimate",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "validate-findings": "tsx skills/ai-spend-discovery/scripts/validate-findings.ts",
    "normalize-findings": "tsx skills/ai-spend-discovery/scripts/normalize-findings.ts",
    "validate-events": "tsx telemetry/scripts/validate-events.ts",
    "validate-estimate": "tsx estimate/scripts/validate-estimate.ts",
    "fetch-quality-scores": "python input-analysis/python/fetch_quality_scores.py",
    "build-quality-scores-from-seed": "python input-analysis/python/build_snapshot_from_seed.py",
    "validate-quality-scores": "tsx input-analysis/scripts/validate-quality-scores.ts",
    "build-classifier-data": "python input-analysis/python/build_training_data.py",
    "bootstrap-classifier": "tsx input-analysis/scripts/bootstrap-classifier-weights.ts",
    "train-classifier": "python input-analysis/python/train_classifier.py --build-data --seed-only",
    "classify-inputs": "python input-analysis/python/classify.py",
    "analyze-inputs": "tsx cli/index.ts analyze-inputs",
    "validate-analyze-inputs": "tsx input-analysis/scripts/validate-analyze-inputs.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "license": "MIT",
  "exports": {
    "./telemetry": "./dist/telemetry/wrappers/index.js",
    "./estimate": "./dist/estimate/index.js"
  }
}
