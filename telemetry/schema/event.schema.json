{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/diagnostic-agent/event.schema.json",
  "title": "Diagnostic Agent Telemetry Event",
  "description": "LLM request telemetry: captures input payload and token counts. Output content is forbidden.",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "provider",
    "model",
    "call_type",
    "input",
    "tokens",
    "schema_version"
  ],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^evt_[a-zA-Z0-9_-]+$",
      "minLength": 5
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "finding_id": {
      "type": "string",
      "pattern": "^f[0-9]{3,}$",
      "description": "Optional link to ai-usage-findings.json finding id from code scan"
    },
    "call_site_fingerprint": {
      "type": "string",
      "pattern": "^cs_[a-f0-9]{8,}$",
      "description": "Stable hash when finding_id is unknown"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "call_type": {
      "type": "string",
      "enum": [
        "chat_completion",
        "embedding",
        "image",
        "speech",
        "agent_framework",
        "unknown"
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "description": "Request payload sent to the provider (messages, prompts, params). Must not include response/completion content."
    },
    "tokens": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "source"],
      "additionalProperties": false,
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "source": {
          "type": "string",
          "enum": ["provider", "estimated", "unknown"]
        }
      }
    },
    "latency_ms": {
      "type": "integer",
      "minimum": 0
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "environment": { "type": "string" },
        "trace_id": { "type": "string" },
        "sdk": { "type": "string" },
        "label": { "type": "string" }
      }
    }
  },
  "anyOf": [{ "required": ["finding_id"] }, { "required": ["call_site_fingerprint"] }]
}
