{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "cli/**/*.ts",
    "lib/**/*.ts",
    "scripts/**/*.ts",
    "skills/**/*.ts",
    "telemetry/**/*.ts",
    "estimate/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "tests"]
}
